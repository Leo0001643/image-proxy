# ================================================================
# docker-compose 环境变量模板。cp .env.example .env 后按需修改。
# ================================================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=image-proxy
MYSQL_PORT=3307

# ---- Redis ----
REDIS_PORT=6389

# ---- Server ----
HTTP_PORT=8080

# ---- Security (生产强制改!) ----
# JWT 签名密钥,至少 32 字符
JWT_SECRET=e42e8ec9512c2398a718973d33f251de04544a237b53a22c9698800f83f3a84b
# AES-256 加密 KEY,用于加密账号的 AT/Cookie 等。必须 64 位 hex(32 字节)
CRYPTO_AES_KEY=Ns1xHH35aba1bpYJBdHrWjQMGMy6f5n8gBY0gLcczrevS4OY

# ---- Backup ----
# 保留最近 N 个备份,0 代表不清理
BACKUP_RETENTION=30
# 是否启用"数据库恢复"端点(超危)。生产默认 false,
# 需要恢复时先设置为 true 重启容器,完成后切回 false。
BACKUP_ALLOW_RESTORE=false
